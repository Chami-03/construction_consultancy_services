RewriteEngine On

# Canonical host and scheme: https://prismoconstructions.com
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.prismoconstructions\.com$ [NC]
RewriteRule ^ https://prismoconstructions.com%{REQUEST_URI} [R=301,L]

# Redirect explicit index file to root
RewriteRule ^index\.html$ / [R=301,L]

# Redirect .html URLs to extensionless versions
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Serve extensionless URLs from corresponding .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
